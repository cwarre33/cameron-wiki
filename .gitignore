# Raw source PDFs (keep markdown versions, ignore binary PDFs)
raw/**/*.pdf
raw/**/*.docx
raw/**/*.pptx

# OSINT scan data (large JSON files and graphs, but keep HTML D3 viz for portfolio)
raw/osint/*.json
raw/osint/*.graphml

# FLS internal content — never publish without explicit sanitization
raw/fls-work/

# Memory graph — commit this to preserve entity relationships
# (uncomment the line below if you want to exclude it)
# .memory/

# Environment and secrets
.env
.env.local
*.env

# Claude Code machine-local settings (can capture command-line args from permission prompts — never commit)
.claude/settings.local.json
*.local.json

# Obsidian — commit shared settings, ignore machine-specific state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/obsidian-git/data.json

# graphify — commit the graph (source of truth across machines), ignore build cache
.graph/cache/
.graph/*.tmp

# Git worktrees
.worktrees/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# Node
node_modules/
npm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo

# graphify temp files
graphify-out/.graphify_*.json
graphify-out/.graphify_*.txt
graphify-out/.graphify_python
